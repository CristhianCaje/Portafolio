---
const {
  title = 'Cristhian Quiñonez | Infraestructura, Seguridad y Datos',
  description = 'Portafolio profesional de Cristhian Quiñonez: infraestructura, ciberseguridad, desarrollo web, análisis de datos y automatización TI.',
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Cristhian Quiñonez" />
    <meta name="theme-color" content="#020617" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/profile-cristhian.jpg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
      const savedLanguage = localStorage.getItem('language') || 'es';
      document.documentElement.dataset.theme = savedTheme || (prefersLight ? 'light' : 'dark');
      document.documentElement.lang = savedLanguage === 'en' ? 'en' : 'es';
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #000000;
    --bg-soft: #031208;
    --surface: rgba(3, 12, 7, 0.78);
    --surface-strong: rgba(3, 12, 7, 0.94);
    --surface-muted: rgba(14, 40, 24, 0.66);
    --text: #d7ffe5;
    --text-strong: #ffffff;
    --muted: #9bc7aa;
    --muted-2: #6b8c77;
    --line: rgba(34, 197, 94, 0.22);
    --primary: #22c55e;
    --primary-strong: #16a34a;
    --secondary: #84cc16;
    --accent: #00e676;
    --primary-rgb: 34, 197, 94;
    --primary-strong-rgb: 22, 163, 74;
    --secondary-rgb: 132, 204, 22;
    --accent-rgb: 0, 230, 118;
    --warning: #f59e0b;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.62);
    --radius-lg: 28px;
    --radius-md: 20px;
    --radius-sm: 14px;
    --container: min(1120px, calc(100% - 40px));
  }

  [data-theme='light'] {
    color-scheme: light;
    --bg: #eaf6ff;
    --bg-soft: #d7edff;
    --surface: rgba(255, 255, 255, 0.86);
    --surface-strong: rgba(255, 255, 255, 0.96);
    --surface-muted: rgba(191, 219, 254, 0.62);
    --text: #14304a;
    --text-strong: #06172f;
    --muted: #4d6680;
    --muted-2: #71859c;
    --line: rgba(37, 99, 235, 0.2);
    --primary: #2563eb;
    --primary-strong: #1d4ed8;
    --secondary: #7c3aed;
    --accent: #0891b2;
    --primary-rgb: 37, 99, 235;
    --primary-strong-rgb: 29, 78, 216;
    --secondary-rgb: 124, 58, 237;
    --accent-rgb: 8, 145, 178;
    --warning: #d97706;
    --shadow: 0 24px 70px rgba(30, 64, 175, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at 14% 12%, rgba(var(--primary-rgb), 0.22), transparent 32rem),
      radial-gradient(circle at 86% 6%, rgba(var(--secondary-rgb), 0.2), transparent 34rem),
      radial-gradient(circle at 50% 86%, rgba(var(--accent-rgb), 0.14), transparent 30rem),
      var(--bg);
    transition: background 0.25s ease, color 0.25s ease;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(var(--primary-rgb), 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--primary-rgb), 0.05) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.65), transparent 72%);
    z-index: -1;
  }

  a {
    color: inherit;
  }

  img,
  svg {
    max-width: 100%;
  }

  button,
  input,
  textarea {
    font: inherit;
  }

  .container {
    width: var(--container);
    margin: 0 auto;
  }

  .section {
    padding: 88px 0;
  }

  .section-title {
    max-width: 760px;
    margin-bottom: 34px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: '';
    width: 28px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--text-strong);
    letter-spacing: -0.04em;
  }

  h2 {
    margin-bottom: 14px;
    font-size: clamp(2rem, 4vw, 3.35rem);
    line-height: 1.03;
  }

  p {
    color: var(--muted);
    line-height: 1.75;
  }

  .gradient-text {
    background: linear-gradient(120deg, var(--primary), var(--secondary), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .glass {
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text-strong);
    text-decoration: none;
    font-weight: 800;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--primary-rgb), 0.48);
  }

  .btn-primary {
    border: 0;
    background: linear-gradient(135deg, var(--primary-strong), var(--secondary));
    color: white;
  }

  .btn-soft {
    background: var(--surface-muted);
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface-muted);
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .card {
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 768px) {
    :root {
      --container: min(100% - 28px, 1120px);
    }

    .section {
      padding: 62px 0;
    }
  }
</style>
