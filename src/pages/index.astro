  <script is:inline>
    const themeButton = document.querySelector("[data-theme-toggle]");
    const themeLabel = document.querySelector("[data-theme-label]");
    const themeIcon = document.querySelector(".theme-icon");
    const languageButton = document.querySelector("[data-language-toggle]");
    const languageLabel = document.querySelector("[data-language-label]");

    const metaCopy = {
      es: {
        title: "Cristhian Quiñonez | Infraestructura, Seguridad y Datos",
        description:
          "Portafolio profesional de Cristhian Quiñonez: infraestructura, ciberseguridad, desarrollo web, análisis de datos y automatización TI.",
        dark: "Oscuro",
        light: "Claro",
      },
      en: {
        title: "Cristhian Quiñonez | Infrastructure, Security and Data",
        description:
          "Professional portfolio of Cristhian Quiñonez: infrastructure, cybersecurity, web development, data analytics and IT automation.",
        dark: "Dark",
        light: "Light",
      },
    };

    const getLanguage = () =>
      localStorage.getItem("language") === "en" ? "en" : "es";

    const syncAria = (lang) => {
      document
        .querySelectorAll("[data-aria-es][data-aria-en]")
        .forEach((element) => {
          const value =
            lang === "en" ? element.dataset.ariaEn : element.dataset.ariaEs;
          if (value) element.setAttribute("aria-label", value);
        });
    };

    const syncThemeText = () => {
      const lang = getLanguage();
      const current = document.documentElement.dataset.theme || "dark";
      if (themeLabel)
        themeLabel.textContent =
          current === "dark" ? metaCopy[lang].dark : metaCopy[lang].light;
      if (themeIcon) themeIcon.textContent = current === "dark" ? "🌙" : "☀️";
    };

    const setLanguage = (lang) => {
      const nextLang = lang === "en" ? "en" : "es";
      localStorage.setItem("language", nextLang);
      document.documentElement.lang = nextLang;

      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const value =
          nextLang === "en" ? element.dataset.en : element.dataset.es;
        if (value) element.textContent = value;
      });

      document.title = metaCopy[nextLang].title;
      const description = document.querySelector('meta[name="description"]');
      if (description)
        description.setAttribute("content", metaCopy[nextLang].description);
      if (languageLabel) languageLabel.textContent = nextLang.toUpperCase();
      syncAria(nextLang);
      syncThemeText();
    };

    setLanguage(getLanguage());

    themeButton?.addEventListener("click", () => {
      const next =
        document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
      syncThemeText();
    });

    languageButton?.addEventListener("click", () => {
      const nextLang = getLanguage() === "es" ? "en" : "es";
      setLanguage(nextLang);
    });
  </script>
